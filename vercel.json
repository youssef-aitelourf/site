{
  "redirects": [
    {
      "source": "/",
      "destination": "/portfolio",
      "permanent": true
    },
    {
      "source": "/admin/health-app",
      "destination": "/admin",
      "permanent": false
    },
    {
      "source": "/admin/health-app/:path*",
      "destination": "/admin",
      "permanent": false
    },
    {
      "source": "/nutrition",
      "destination": "/admin/nutrition",
      "permanent": false
    },
    {
      "source": "/nutrition/:path*",
      "destination": "/admin/nutrition",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/portfolio",
      "destination": "https://portfolio-2-youssef-ait-elourfs-projects.vercel.app/portfolio"
    },
    {
      "source": "/portfolio/:path*",
      "destination": "https://portfolio-2-youssef-ait-elourfs-projects.vercel.app/portfolio/:path*"
    },
    {
      "source": "/admin/nutrition",
      "destination": "https://nutrition-youssef-ait-elourfs-projects.vercel.app/admin/nutrition"
    },
    {
      "source": "/admin/nutrition/:path*",
      "destination": "https://nutrition-youssef-ait-elourfs-projects.vercel.app/admin/nutrition/:path*"
    }
  ]
}
